    new_p.set_defaults(func = new)
    eval_p = subparsers.add_parser("evaluate", help = "compare Traitar predictions against a given standard of truth") 
    eval_p.add_argument("traitar_pred_f",  help = "phenotype prediction matrix as return by Traitar")
    eval_p.add_argument("gold_standard_f",  help = "phenotype matrix with standard of truth")
    eval_p.add_argument("--are_pt_ids",  help = "set if the gold standard phenotype are index via phenotype ids rather than accessions", action = 'store_true')
    eval_p.add_argument("--phenotype_archive",  help = "need if gold standard uses an accession index for mapping")
    eval_p.add_argument("--min_samples", "-m", help='minimum number of positive and negative samples to consider phenotypes for calculation of the macro accuracy', default = 5, type = int)
    eval_p.add_argument("out",  help = "output directory")
    eval_p.set_defaults(func = evaluate)
    data_p.add_argument("Pfam_db",  help = "directory where Pfam HMMs will be downloaded and extracted [Pfam_db]")
    data_p.add_argument("--local", "-l", action = 'store_true', help = "use a directory where you have already downloaded Pfam HMMs (must be named 'Pfam-A.hmm')")
    data_p.set_defaults(func = get_external_data.download)
    args = parser.parse_args()

    if not hasattr(args, 'func'):
        sys.stderr.write(
            "No command given.\n\n"
            "Common examples:\n"
            "  traitar2 phenotype -d genomes_dir -o results\n"
            "  traitar2 phenotype -d genes_dir -m from_genes -o results\n"
            "  traitar2 pfam pfam_db\n\n"
            "For command-specific help, run: traitar2 phenotype -h\n\n"
        )
        parser.print_help(sys.stderr)
        sys.exit(2)
    
    # Consolidation logic for parent_p arguments (input_dir, sample2file, mode, output_dir)
    # This identifies if the user used positional arguments or flags
    if hasattr(args, 'pos_args'):
        pos_args = list(args.pos_args)
        
        # Fill in missing values from positional arguments
        # For 'plot', the first positional argument is likely the results (output) directory
        if hasattr(args, 'func') and args.func == plot_heatmap:
            if args.output_dir == 'traitar_results' and args.input_dir is None and pos_args:
                args.output_dir = pos_args.pop(0)
                # Default input_dir to the same as output_dir for plotting
                args.input_dir = args.output_dir
        
        if args.input_dir is None and pos_args:
            args.input_dir = pos_args.pop(0)
        if args.sample2file is None and pos_args:
            # If the next positional argument is a known mode, the user probably skipped sample2file
            modes = ["from_genes", "from_nucleotides", "from_annotation_summary"]
            if pos_args[0] in modes:
                pass
            else:
                args.sample2file = pos_args.pop(0)
        if (args.mode == 'from_nucleotides' or args.mode is None) and pos_args:
            if pos_args[0] in modes:
                args.mode = pos_args.pop(0)
        if (args.output_dir == 'traitar_results' or args.output_dir is None) and pos_args:
            args.output_dir = pos_args.pop(0)

        # Validate mode choice manually if it came from positional
        modes = ["from_genes", "from_nucleotides", "from_annotation_summary"]
        if args.mode and args.mode not in modes:
             parser.error("argument mode: invalid choice: %r (choose from %s)" % (args.mode, ", ".join(map(repr, modes))))

        # Required check for commands using parent_p
        if hasattr(args, 'func') and args.func in [phenolyze, plot_heatmap, annotate]:
            # Heuristic for 'plot': accept either the run root or any subdir under phenotype_prediction.
            # In both cases, the plot output root must be the original run directory.
            if args.func == plot_heatmap and args.input_dir:
                input_path = Path(args.input_dir)
                if "phenotype_prediction" in input_path.parts:
                    idx = input_path.parts.index("phenotype_prediction")
                    args.output_dir = str(Path(*input_path.parts[:idx])) if idx > 0 else "."
                elif (input_path / "phenotype_prediction").exists():
                    args.output_dir = args.input_dir
            
            # For 'plot', default input_dir to output_dir if not specified
            if args.func == plot_heatmap and not args.input_dir and args.output_dir:
                args.input_dir = args.output_dir

            missing = []
            if not args.input_dir: missing.append("input_dir (-d)")
            if missing:
                parser.error("the following arguments are required: %s" % ", ".join(missing))

    try:
        args.func(args)
    except TraitarError as e:
        sys.stderr.write(f"\n{RED}{BOLD}❌ ERROR:{RESET} {e}\n\n")
        sys.exit(1)
    except KeyboardInterrupt:
        sys.stderr.write(f"\n{YELLOW}⚠ Execution interrupted by user.{RESET}\n")
        sys.exit(1)
    except Exception as e:
        sys.stderr.write(f"\n{RED}{BOLD}❌ UNEXPECTED ERROR:{RESET} {e}\n")
        sys.stderr.write(f"{YELLOW}If this persists, please report it at: https://github.com/GenomicaMicrob/traitar2/issues{RESET}\n")
        import traceback
        # Save traceback to a file instead of flooding the screen
        tb_file = "traitar_error_traceback.txt"
        with open(tb_file, "w") as f:
            traceback.print_exc(file=f)
        sys.stderr.write(f"Detailed traceback saved to: {tb_file}\n\n")
        sys.exit(1)
